{
  "name": "jarvis-frontend",
  "version": "0.1.7",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Niswitonyn/AI-Life-Assistant-Guide.git"
  },
  "main": "electron.js",
  "scripts": {
    "dev": "vite",
    "electron": "set ELECTRON_RUN_AS_NODE=&& wait-on http://localhost:5173 && electron .",
    "electron:dev": "set ELECTRON_RUN_AS_NODE=&& wait-on http://localhost:5173 && electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron:dev\"",
    "build": "vite build",
    "build:renderer": "vite build",
    "preview": "vite preview",
    "pack": "npm run build:renderer && electron-builder --dir",
    "dist": "npm run build:renderer && electron-builder",
    "dist:win": "npm run build:renderer && electron-builder --win nsis",
    "dist:win:standalone": "npm run build:renderer && electron-builder --win nsis",
    "dist:win:standalone:publish": "npm run build:renderer && electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9",
    "electron-store": "^11.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.13.1",
    "vosk-browser": "^0.0.8"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^25.1.8",
    "vite": "^5.0.0",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.jarvis.assistant",
    "productName": "Jarvis Assistant",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist/index.html",
      "electron.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/jarvis-backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "${env.GH_OWNER}",
        "repo": "${env.GH_REPO}",
        "releaseType": "release"
      }
    ]
  }
}
