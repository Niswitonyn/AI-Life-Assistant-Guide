# .env Configuration Example

# ========================================
# JWT Authentication
# ========================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-super-secret-key-change-this-in-production-12345
JWT_EXPIRE_MINUTES=10080

# ========================================
# Google OAuth Setup
# ========================================
# Get from Google Cloud Console:
# 1. Create project in Google Cloud
# 2. Enable Gmail API, Calendar API
# 3. Create OAuth 2.0 Client ID (Desktop/Web)
# 4. Download credentials.json

GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# ========================================
# AI Provider Configuration
# ========================================
# Options: openai, ollama, gemini
DEFAULT_PROVIDER=ollama
DEFAULT_MODEL=llama3

# Uncomment for specific providers:
# DEFAULT_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# DEFAULT_PROVIDER=gemini
# GOOGLE_API_KEY=AIza...

# ========================================
# Voice Configuration
# ========================================
# Whisper model size: tiny.en, base.en, small.en, medium.en
WHISPER_MODEL_SIZE=tiny.en

# Voice transcription timeout in seconds
VOICE_TRANSCRIBE_TIMEOUT_SECONDS=20

# Minimum audio size in bytes
VOICE_MIN_AUDIO_BYTES=2000

# Minimum transcript length in characters
VOICE_MIN_TRANSCRIPT_CHARS=2

# ========================================
# Data Directory (Optional)
# ========================================
# Custom path for data storage (database, credentials, etc.)
# If not set, defaults to: backend/data/
# AI_LIFE_DATA_DIR=/path/to/custom/data/dir

# ========================================
# Database (Optional)
# ========================================
# Default: SQLite (backend/data/database/assistant.db)
# DATABASE_URL=sqlite:///./data/database/assistant.db

# ========================================
# Environment
# ========================================
# Set to true in production
DEBUG=false
